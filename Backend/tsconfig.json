{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,

    "types": ["node", "multer"],
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },

  "include": ["src/**/*"]
}